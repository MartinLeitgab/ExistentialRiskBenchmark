.PHONY: test test-unit test-integration test-cov test-fast clean

# Run all tests (pipeline_a_scenarios test suite)
test:
	pytest pipeline_a_scenarios/tests/ -v

# Run only unit tests (fast)
test-unit:
	pytest pipeline_a_scenarios/tests/unit/ -v

# Run only integration tests
test-integration:
	pytest pipeline_a_scenarios/tests/ -v -m integration

# Run with coverage
test-cov:
	pytest pipeline_a_scenarios/tests/ -v --cov=pipeline_a_scenarios --cov-report=html --cov-report=term-missing

# Run fast tests (unit tests in parallel)
test-fast:
	pytest pipeline_a_scenarios/tests/unit/ -v -n auto

# Clean test artifacts
clean:
	rm -rf .pytest_cache
	rm -rf htmlcov
	rm -rf .coverage
	rm -rf pipeline_a_scenarios/tests/__pycache__
	rm -rf pipeline_a_scenarios/tests/unit/__pycache__
	find . -type d -name __pycache__ -exec rm -rf {} +
